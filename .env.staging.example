# Dedicated staging database. Never point this at production.
DATABASE_URL=postgresql://staging_user:staging_password@staging-host:5432/pushup_tracker_staging

# Staging Supabase project. Must not point at production auth.
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key

# Optional: needed only for testing DELETE /api/admin/rooms/:code on staging.
ADMIN_API_KEY=change-me-auth-staging
