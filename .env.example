# PostgreSQL (Yandex Cloud Managed PostgreSQL)
# Прод: selectywellness_app | Тест: selectywellness_app_test
# Порт 6432 = встроенный Odyssey pooler (Yandex Cloud)
DATABASE_URL=postgresql://user:password@host:6432/dbname?sslmode=no-verify

# Supabase Auth (только авторизация, не БД)
# Прод и тест — разные проекты Supabase
# service_role key не используется — только anon key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin API key (для DELETE /api/admin/rooms/:code)
ADMIN_API_KEY=change-me
