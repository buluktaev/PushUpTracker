# Production Postgres. Must not point at staging.
DATABASE_URL=postgresql://prod_user:prod_password@prod-host:5432/pushup_tracker

# Production Supabase project. Must be the same project used for email auth and browser sessions.
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key

# Optional: needed only for internal admin delete route.
ADMIN_API_KEY=change-me-production
