{
  "name": "pushup-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "./scripts/start-dev-worktree.sh",
    "dev:next": "prisma migrate deploy && next dev",
    "studio:test": "./scripts/prisma-studio-test.sh",
    "typecheck": "tsc --noEmit",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "audit:legacy": "bash ./scripts/audit-legacy.sh",
    "smoke:health": "node ./scripts/smoke-health.mjs",
    "smoke:browser": "playwright test",
    "smoke:browser:headed": "playwright test --headed",
    "preprod:static": "npm run typecheck && npm run lint && npm run build && npm run audit:legacy"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.32",
    "@number-flow/react": "^0.6.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@types/pg": "^8.18.0",
    "dotenv": "^17.3.1",
    "geist": "^1.7.0",
    "ldrs": "^1.1.9",
    "next": "14.2.35",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "react": "^18",
    "react-dom": "^18",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "agentation": "^3.0.2",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
